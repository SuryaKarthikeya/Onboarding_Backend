# API Settings
PROJECT_NAME="Realify AI Onboarding Backend"
DEBUG=true
HOST=127.0.0.1
PORT=8000

# MongoDB Configuration
MONGODB_URI="mongodb://localhost:27017"
DATABASE_NAME="realify_onboarding"

# Redis Configuration
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# Security (JWT & AES Cryptography)
# Generate a secure key: openssl rand -hex 32
JWT_SECRET="super_secret_jwt_signature_key_change_me_in_production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Generate a 32-byte url-safe base64 key for AES-256-GCM encryption
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="change_me_to_a_32_byte_cryptography_compatible_key="

# Twilio Configuration (WhatsApp OTPs)
TWILIO_ACCOUNT_SID="ACyour_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# E-commerce Integrations
# Shopify Settings
SHOPIFY_CLIENT_ID="your_shopify_client_id"
SHOPIFY_CLIENT_SECRET="your_shopify_client_secret"
SHOPIFY_REDIRECT_URI="http://localhost:8000/v1/marketplace/shopify/callback"
